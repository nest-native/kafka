{
  "name": "@nest-native/kafka",
  "version": "0.3.0",
  "description": "Decorator-first NestJS Kafka integration built on Confluent's officially supported @confluentinc/kafka-javascript client",
  "keywords": [
    "nestjs",
    "kafka",
    "confluent",
    "kafka-javascript",
    "microservices",
    "transport",
    "consumer",
    "producer",
    "decorators",
    "dependency-injection",
    "typescript"
  ],
  "author": "Rodrigo Nogueira",
  "license": "MIT",
  "homepage": "https://github.com/nest-native/kafka#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nest-native/kafka.git",
    "directory": "packages/kafka"
  },
  "bugs": {
    "url": "https://github.com/nest-native/kafka/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "require": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.js",
    "dist/**/*.js.map"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {},
  "peerDependencies": {
    "@confluentinc/kafka-javascript": "^1.9",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "class-validator": "^0.14.0",
    "reflect-metadata": "^0.1.12 || ^0.2.0",
    "rxjs": "^7.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@confluentinc/kafka-javascript": {
      "optional": true
    },
    "class-validator": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/microservices": "^11.1.27",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typescript": "^6.0.3"
  }
}
