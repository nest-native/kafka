{
  "name": "nest-native-kafka-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Community standalone monorepo for @nest-native/kafka",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "sample/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "TS_NODE_PROJECT=tsconfig.spec.json node --require ts-node/register --require reflect-metadata --test packages/kafka/test/*.spec.ts",
    "test:report": "node scripts/run-node-test-report.cjs",
    "test:cov": "c8 --all --include \"packages/kafka/**/*.ts\" --exclude \"packages/kafka/test/**\" --exclude \"packages/kafka/interfaces.ts\" --exclude \"packages/kafka/index.ts\" --exclude \"packages/kafka/testing/index.ts\" --exclude \"**/*.d.ts\" --exclude \"**/dist/**\" --reporter text --reporter text-summary --reporter json-summary --reporter lcov --check-coverage --branches 100 --functions 100 --lines 100 --statements 100 npm run test:report",
    "test:watch": "TS_NODE_PROJECT=tsconfig.spec.json node --watch --require ts-node/register --require reflect-metadata --test packages/kafka/test/*.spec.ts",
    "complexity:check": "eslint --config eslint.complexity-check.config.mjs \"packages/kafka/**/*.ts\"",
    "complexity:report": "node scripts/collect-cognitive-complexity.mjs",
    "release:check:readme-links": "node scripts/check-readme-links.mjs",
    "release:check:sample-versions": "node scripts/check-sample-version-sync.mjs",
    "release:check:pack": "npm run build --workspace @nest-native/kafka && node scripts/check-package-pack.mjs",
    "release:check": "npm run release:check:readme-links && npm run release:check:sample-versions && npm run release:check:pack",
    "security:audit": "npm audit --audit-level=high",
    "showcase": "node scripts/run-optional-workspace.cjs nest-native-kafka-showcase test",
    "sample:focused": "node scripts/run-focused-samples.mjs",
    "sample": "npm run showcase && npm run sample:focused",
    "ci:sample": "npm run sample",
    "ci": "npm run typecheck && npm run test:cov && npm run complexity:check && npm run complexity:report && npm run release:check && npm run security:audit && npm run ci:sample"
  },
  "engines": {
    "node": ">=20"
  },
  "scarfSettings": {
    "enabled": false
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.26",
    "@nestjs/core": "^11.1.26",
    "@nestjs/microservices": "^11.1.26",
    "@nestjs/testing": "^11.1.26",
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.59.0",
    "c8": "^11.0.0",
    "eslint": "^10.4.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "packageManager": "npm@11.13.0"
}
